page {
  background: #f7f7f4;
  color: #1f2933;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.page {
  padding: 24rpx;
}

.top-title {
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.2;
}

.muted {
  color: #697386;
  font-size: 26rpx;
}

.search {
  height: 88rpx;
  margin: 24rpx 0;
  padding: 0 24rpx;
  border: 1rpx solid #e2e5e9;
  border-radius: 16rpx;
  background: #ffffff;
}

.segmented {
  display: flex;
  gap: 8rpx;
  padding: 8rpx;
  border: 1rpx solid #e2e5e9;
  border-radius: 16rpx;
  background: #edf0ed;
}

.segmented-item {
  flex: 1;
  height: 72rpx;
  border-radius: 12rpx;
  text-align: center;
  line-height: 72rpx;
  font-weight: 700;
  color: #697386;
}

.segmented-item.active {
  background: #ffffff;
  color: #176b5b;
}

.filter-row {
  display: flex;
  gap: 16rpx;
  margin: 20rpx 0;
  overflow-x: auto;
  white-space: nowrap;
}

.chip {
  padding: 14rpx 22rpx;
  border: 1rpx solid #e2e5e9;
  border-radius: 16rpx;
  background: #ffffff;
  color: #697386;
  font-size: 26rpx;
}

.section-title {
  margin: 32rpx 0 16rpx;
  font-size: 32rpx;
  font-weight: 800;
}

.card {
  margin-bottom: 16rpx;
  padding: 20rpx;
  border: 1rpx solid #e2e5e9;
  border-radius: 16rpx;
  background: #ffffff;
}

.card-row {
  display: flex;
  gap: 20rpx;
}

.thumb {
  width: 152rpx;
  height: 152rpx;
  border-radius: 14rpx;
  background: #eef3f1;
}

.card-main {
  flex: 1;
  min-width: 0;
}

.card-title {
  font-size: 30rpx;
  font-weight: 800;
}

.price {
  margin-top: 8rpx;
  color: #d97706;
  font-weight: 800;
}

.badge {
  display: inline-block;
  margin-top: 8rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #e7f6ef;
  color: #067647;
  font-size: 22rpx;
  font-weight: 700;
}

.primary-button,
.secondary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 16rpx;
  font-weight: 800;
}

.primary-button {
  background: #176b5b;
  color: #ffffff;
}

.secondary-button {
  border: 1rpx solid #e2e5e9;
  background: #ffffff;
  color: #1f2933;
}

.form {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.field {
  padding: 20rpx;
  border: 1rpx solid #e2e5e9;
  border-radius: 16rpx;
  background: #ffffff;
}

.textarea {
  min-height: 180rpx;
}

.detail-image {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 520rpx;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
  background: #eef3f1;
  color: #176b5b;
  font-weight: 800;
}

.actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.actions .primary-button,
.actions .secondary-button {
  flex: 1;
}

<view class="page">
  <view class="detail-image">
    <image wx:if="{{item.cover_image_url}}" src="{{item.cover_image_url}}" mode="aspectFill"></image>
    <text wx:else>商品图片</text>
  </view>

  <view class="card">
    <view class="detail-title-row">
      <view class="card-title">{{item.title}}</view>
      <view class="detail-status status-{{item.status}}">{{item.status_label}}</view>
    </view>
    <view class="price">{{item.price}}元</view>
    <view class="muted">{{item.category_label}} · {{item.condition_label}} · {{item.dormitory}}</view>
    <view class="muted">{{item.handover_location}}</view>
  </view>

  <view class="card">
    <view class="section-title">描述</view>
    <view>{{item.description}}</view>
  </view>

  <view class="card contact-panel">
    <view class="section-title">联系卖家</view>
    <view wx:if="{{contact.wechat_id}}">
      <view class="muted">微信号</view>
      <view class="wechat-id">{{contact.wechat_id}}</view>
      <view class="primary-button" bindtap="copyWechat">复制微信号</view>
    </view>
    <view wx:else>
      <view class="muted">登录后查看联系方式</view>
      <view class="primary-button" bindtap="goLogin">模拟登录</view>
    </view>
  </view>

  <view class="actions">
    <view class="secondary-button" bindtap="reportItem">举报</view>
    <view class="primary-button" bindtap="copyShareText">复制分享文案</view>
  </view>
</view>

.detail-image image {
  width: 100%;
  height: 100%;
}

.detail-image-fallback {
  display: flex;
  width: 100%;
  height: 100%;
  align-items: center;
  justify-content: center;
  background:
    radial-gradient(circle at 50% 42%, rgba(111, 44, 145, 0.12) 0, rgba(111, 44, 145, 0.12) 72rpx, transparent 74rpx),
    linear-gradient(135deg, #eee9f5 0%, #d9c8ec 100%);
  color: #6F2C91;
  font-weight: 800;
}

.detail-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.detail-title-row .card-title {
  flex: 1;
}

.detail-status {
  flex: 0 0 auto;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(111, 44, 145, 0.92);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 800;
}

.status-reserved {
  background: rgba(255, 140, 0, 0.92);
}

.status-sold,
.status-off_shelf {
  background: rgba(31, 41, 51, 0.76);
}

.owner-actions {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin: 20rpx 0;
}

.owner-actions .primary-button,
.owner-actions .secondary-button {
  height: 76rpx;
  border-radius: 14rpx;
  font-size: 26rpx;
}

.contact-panel {
  border-color: rgba(111, 44, 145, 0.22);
  background: #fbf8ff;
  box-shadow: 0 10rpx 28rpx rgba(65, 30, 103, 0.08);
}

.wechat-id {
  margin: 10rpx 0 18rpx;
  color: #6F2C91;
  font-size: 36rpx;
  font-weight: 900;
}

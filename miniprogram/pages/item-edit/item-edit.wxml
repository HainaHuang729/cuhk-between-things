<view class="page">
  <view class="top-title">发布商品</view>
  <form class="form" bindsubmit="submit">
    <input class="field" name="title" placeholder="标题，例如 Dell 27寸显示器" />
    <input class="field" name="price" type="digit" placeholder="价格 HKD" />
    <picker mode="selector" range="{{categories}}" range-key="label" bindchange="onCategoryChange">
      <view class="field">{{categoryLabel}}</view>
    </picker>
    <picker mode="selector" range="{{conditions}}" range-key="label" bindchange="onConditionChange">
      <view class="field">{{conditionLabel}}</view>
    </picker>
    <input class="field" name="dormitory" placeholder="宿舍，例如 56座" />
    <input class="field" name="handover_location" placeholder="交收地点" />
    <textarea class="field textarea" name="description" placeholder="描述" />
    <view class="secondary-button" bindtap="chooseImages">选择图片（最多9张）</view>
    <button class="primary-button" form-type="submit">提交</button>
  </form>
</view>

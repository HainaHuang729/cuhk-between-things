<view class="page">
  <view class="top-title">发起拼团</view>
  <form class="form" bindsubmit="submit">
    <input class="field" name="title" placeholder="标题，例如 Costco纸巾拼团" />
    <input class="field" name="source_platform" placeholder="来源平台" />
    <input class="field" name="target_size" type="number" placeholder="目标人数" />
    <input class="field" name="total_price" type="digit" placeholder="总价，可选" />
    <input class="field" name="per_person_price" type="digit" placeholder="人均，可选" />
    <input class="field" name="deadline_at" placeholder="截止时间 ISO，例如 2026-06-22T16:00:00Z" />
    <input class="field" name="dormitory" placeholder="宿舍，例如 56座" />
    <input class="field" name="handover_location" placeholder="交收地点" />
    <textarea class="field textarea" name="description" placeholder="描述" />
    <button class="primary-button" form-type="submit">提交</button>
  </form>
</view>

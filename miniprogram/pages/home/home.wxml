<view class="page">
  <view class="search-wrap">
    <view class="search-box">
      <input
        class="search-input"
        placeholder="搜索商品"
        value="{{q}}"
        confirm-type="search"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
      />
      <view wx:if="{{q}}" class="search-clear" bindtap="clearSearch">×</view>
    </view>
    <view class="status-row">
      <view
        wx:for="{{statusFilters}}"
        wx:key="value"
        class="status-chip {{status == item.value ? 'active' : ''}}"
        data-status="{{item.value}}"
        bindtap="setStatus"
      >{{item.label}}</view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading-state">加载中</view>

  <view wx:elif="{{!items.length}}" class="empty-state">
    <view class="empty-title">{{emptyTitle}}</view>
    <view class="empty-copy">{{emptyCopy}}</view>
  </view>

  <view wx:else class="market-masonry">
    <view
      wx:for="{{items}}"
      wx:key="id"
      class="item-card"
      hover-class="item-card-hover"
      data-id="{{item.id}}"
      bindtap="goItem"
    >
      <view class="item-photo">
        <image
          wx:if="{{item.cover_image_url && !item.image_error}}"
          class="item-image"
          src="{{item.cover_image_url}}"
          mode="widthFix"
          data-id="{{item.id}}"
          binderror="onImageError"
        ></image>
        <view wx:else class="item-fallback" style="height: {{item.placeholder_height || 260}}rpx;"></view>
        <view class="status-badge status-{{item.status}}">{{item.status_label}}</view>
      </view>
      <view class="item-info">
        <view class="item-title">{{item.title}}</view>
        <view class="item-price">{{item.price}}元</view>
        <view class="item-meta">{{item.seller_name}} · {{item.dormitory}}</view>
      </view>
    </view>
  </view>
</view>

<view class="page">
  <view class="search-wrap">
    <input
      class="search-input"
      placeholder="搜索商品"
      value="{{q}}"
      confirm-type="search"
      bindinput="onSearchInput"
      bindconfirm="loadFeed"
    />
  </view>

  <view class="market-grid">
    <view wx:for="{{items}}" wx:key="id" class="item-card" data-id="{{item.id}}" bindtap="goItem">
      <view class="item-photo">
        <image wx:if="{{item.cover_image_url}}" src="{{item.cover_image_url}}" mode="aspectFill"></image>
        <view wx:else class="item-fallback"></view>
      </view>
      <view class="item-info">
        <view class="item-title">{{item.title}}</view>
        <view class="item-price">HKD {{item.price}}</view>
        <view class="item-meta">{{item.dormitory}}</view>
      </view>
    </view>
  </view>
</view>

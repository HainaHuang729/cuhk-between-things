.page {
  min-height: 100vh;
  padding: 20rpx 18rpx 28rpx;
  background: #faf9fc;
}

.search-wrap {
  position: sticky;
  top: 0;
  z-index: 5;
  padding-bottom: 16rpx;
  background: #faf9fc;
}

.search-box {
  position: relative;
}

.search-input {
  height: 76rpx;
  padding: 0 76rpx 0 28rpx;
  border: 1rpx solid rgba(111, 44, 145, 0.14);
  border-radius: 999rpx;
  background: #ffffff;
  color: #1f2933;
  font-size: 28rpx;
  box-shadow: 0 6rpx 18rpx rgba(65, 30, 103, 0.06);
}

.search-clear {
  position: absolute;
  right: 18rpx;
  top: 12rpx;
  display: flex;
  width: 52rpx;
  height: 52rpx;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: #f1edf5;
  color: #6F2C91;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1;
}

.status-row {
  display: flex;
  gap: 12rpx;
  margin-top: 14rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.status-chip {
  flex: 0 0 auto;
  padding: 12rpx 20rpx;
  border: 1rpx solid rgba(111, 44, 145, 0.14);
  border-radius: 999rpx;
  background: #ffffff;
  color: #697386;
  font-size: 24rpx;
  font-weight: 700;
}

.status-chip.active {
  border-color: #6F2C91;
  background: #6F2C91;
  color: #ffffff;
}

.market-masonry {
  column-count: 2;
  column-gap: 18rpx;
}

.item-card {
  display: inline-block;
  overflow: hidden;
  width: 100%;
  margin: 0 0 18rpx;
  border-radius: 16rpx;
  background: #ffffff;
  break-inside: avoid;
  box-shadow: 0 6rpx 18rpx rgba(65, 30, 103, 0.07);
  transition: opacity 120ms ease, transform 120ms ease;
}

.item-card-hover {
  opacity: 0.86;
  transform: scale(0.985);
}

.item-photo {
  position: relative;
  width: 100%;
  overflow: hidden;
  background: #eee9f5;
}

.item-image {
  display: block;
  width: 100%;
}

.item-fallback {
  display: flex;
  width: 100%;
  align-items: center;
  justify-content: center;
  background:
    radial-gradient(circle at 50% 42%, rgba(111, 44, 145, 0.12) 0, rgba(111, 44, 145, 0.12) 54rpx, transparent 56rpx),
    linear-gradient(135deg, #eee9f5 0%, #d9c8ec 100%);
}

.status-badge {
  position: absolute;
  right: 10rpx;
  top: 10rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(111, 44, 145, 0.9);
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 800;
}

.status-reserved {
  background: rgba(255, 140, 0, 0.92);
}

.status-sold,
.status-off_shelf {
  background: rgba(31, 41, 51, 0.76);
}

.item-info {
  padding: 14rpx 14rpx 16rpx;
}

.item-title {
  display: -webkit-box;
  overflow: hidden;
  color: #1f2933;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 36rpx;
  word-break: break-all;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.item-price {
  margin-top: 10rpx;
  overflow: hidden;
  color: #6F2C91;
  font-size: 32rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-meta {
  margin-top: 6rpx;
  overflow: hidden;
  color: #697386;
  font-size: 22rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.loading-state,
.empty-state {
  display: flex;
  min-height: 420rpx;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  background: #ffffff;
  color: #697386;
  font-size: 28rpx;
}

.empty-state {
  flex-direction: column;
  gap: 10rpx;
}

.empty-title {
  color: #1f2933;
  font-size: 32rpx;
  font-weight: 800;
}

.empty-copy {
  color: #697386;
  font-size: 26rpx;
}

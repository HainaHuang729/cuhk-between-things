.page {
  min-height: 100vh;
  padding: 20rpx 18rpx 28rpx;
  background: #faf9fc;
}

.search-wrap {
  position: sticky;
  top: 0;
  z-index: 5;
  padding-bottom: 16rpx;
  background: #faf9fc;
}

.search-input {
  height: 76rpx;
  padding: 0 28rpx;
  border: 1rpx solid rgba(111, 44, 145, 0.14);
  border-radius: 999rpx;
  background: #ffffff;
  color: #1f2933;
  font-size: 28rpx;
  box-shadow: 0 6rpx 18rpx rgba(65, 30, 103, 0.06);
}

.market-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.item-card {
  overflow: hidden;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 6rpx 18rpx rgba(65, 30, 103, 0.07);
}

.item-photo {
  position: relative;
  width: 100%;
  height: 350rpx;
  background: #eee9f5;
}

.item-photo image {
  width: 100%;
  height: 100%;
}

.item-fallback {
  width: 100%;
  height: 100%;
  background:
    radial-gradient(circle at 50% 42%, rgba(111, 44, 145, 0.12) 0, rgba(111, 44, 145, 0.12) 54rpx, transparent 56rpx),
    linear-gradient(135deg, #eee9f5 0%, #d9c8ec 100%);
}

.status-badge {
  position: absolute;
  right: 10rpx;
  top: 10rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(111, 44, 145, 0.9);
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 800;
}

.status-reserved {
  background: rgba(255, 140, 0, 0.92);
}

.status-sold,
.status-off_shelf {
  background: rgba(31, 41, 51, 0.76);
}

.item-info {
  padding: 14rpx 14rpx 16rpx;
}

.item-title {
  display: -webkit-box;
  min-height: 72rpx;
  overflow: hidden;
  color: #1f2933;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 36rpx;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.item-price {
  margin-top: 10rpx;
  overflow: hidden;
  color: #6F2C91;
  font-size: 32rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-meta {
  margin-top: 6rpx;
  overflow: hidden;
  color: #697386;
  font-size: 22rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.loading-state,
.empty-state {
  display: flex;
  min-height: 420rpx;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  background: #ffffff;
  color: #697386;
  font-size: 28rpx;
}

.empty-state {
  flex-direction: column;
  gap: 10rpx;
}

.empty-title {
  color: #1f2933;
  font-size: 32rpx;
  font-weight: 800;
}

.empty-copy {
  color: #697386;
  font-size: 26rpx;
}

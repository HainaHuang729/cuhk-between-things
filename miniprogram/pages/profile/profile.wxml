<view class="page">
  <view class="top-title">我的</view>

  <view wx:if="{{!user.id}}" class="card">
    <view class="card-title">未登录</view>
    <view class="muted">登录后查看我的发布和联系方式记录</view>
  </view>

  <block wx:else>
    <view class="card profile-card">
      <view class="card-title">{{user.display_name}}</view>
      <view class="muted">{{user.email}}</view>
      <view class="muted">微信号 {{user.wechat_id}}</view>
    </view>

    <view class="profile-actions">
      <view class="primary-button" bindtap="goNewItem">发布商品</view>
      <view class="secondary-button" bindtap="logout">退出登录</view>
    </view>

    <view class="section-title">我发布的商品</view>
    <view wx:if="{{!myItems.length}}" class="empty-box">暂无发布</view>
    <view
      wx:for="{{myItems}}"
      wx:key="id"
      class="profile-item"
      hover-class="profile-item-hover"
      data-id="{{item.id}}"
      bindtap="goItem"
    >
      <view class="profile-item-main">
        <view class="profile-item-title">{{item.title}}</view>
        <view class="muted">{{item.dormitory}}</view>
      </view>
      <view class="profile-item-side">
        <view class="profile-price">{{item.price}}元</view>
        <view class="profile-status status-{{item.status}}">{{item.status_label}}</view>
      </view>
    </view>

    <view class="section-title">我联系过的商品</view>
    <view wx:if="{{!contactedItems.length}}" class="empty-box">暂无联系记录</view>
    <view
      wx:for="{{contactedItems}}"
      wx:key="id"
      class="profile-item"
      hover-class="profile-item-hover"
      data-id="{{item.id}}"
      bindtap="goItem"
    >
      <view class="profile-item-main">
        <view class="profile-item-title">{{item.title}}</view>
        <view class="muted">{{item.seller_name}} · {{item.dormitory}}</view>
      </view>
      <view class="profile-item-side">
        <view class="profile-price">{{item.price}}元</view>
        <view class="profile-status status-{{item.status}}">{{item.status_label}}</view>
      </view>
    </view>
  </block>

  <view wx:if="{{!user.id}}" class="primary-button" bindtap="goLogin">模拟登录</view>
</view>

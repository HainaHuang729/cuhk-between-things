.page {
  min-height: 100vh;
  padding: 20rpx 18rpx 28rpx;
  background: #faf9fc;
}

.wanted-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.wanted-card {
  min-height: 220rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 6rpx 18rpx rgba(65, 30, 103, 0.07);
  transition: opacity 120ms ease, transform 120ms ease;
}

.wanted-card-hover {
  opacity: 0.86;
  transform: scale(0.985);
}

.wanted-title {
  display: -webkit-box;
  min-height: 72rpx;
  overflow: hidden;
  color: #1f2933;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 36rpx;
  word-break: break-all;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.wanted-price {
  margin-top: 14rpx;
  color: #6F2C91;
  font-size: 30rpx;
  font-weight: 900;
}

.wanted-meta,
.wanted-desc {
  margin-top: 8rpx;
  overflow: hidden;
  color: #697386;
  font-size: 22rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

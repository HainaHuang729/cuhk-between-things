<view class="page">
  <view class="feed">
    <view
      wx:for="{{groups}}"
      wx:key="id"
      class="group-card"
      hover-class="group-card-hover"
      data-id="{{item.id}}"
      bindtap="goGroup"
    >
      <view class="group-top">
        <view class="group-title">{{item.title}}</view>
        <view class="group-status">{{item.status_label}}</view>
      </view>
      <view class="group-meta">{{item.source_platform}} · {{item.handover_location}}</view>
      <view class="group-bottom">
        <view class="group-count">{{item.current_size}}/{{item.target_size}}</view>
        <view class="group-deadline">{{item.deadline_text}}</view>
      </view>
    </view>
  </view>
</view>

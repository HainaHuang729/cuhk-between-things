<view class="page">
  <view class="top-title">CUHK 邮箱登录</view>
  <view class="muted">支持 @link.cuhk.edu.hk 和 @cuhk.edu.hk</view>

  <view class="form">
    <input class="field" value="{{email}}" bindinput="onEmailInput" placeholder="name@link.cuhk.edu.hk" />
    <view class="secondary-button" bindtap="requestOtp">发送验证码</view>
    <input class="field" value="{{token}}" bindinput="onTokenInput" placeholder="邮箱验证码" />
    <view class="primary-button" bindtap="verifyOtp">登录</view>
  </view>
</view>
